{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/pagination/macro.njk" import govukPagination %}

{% extends "template.njk" %}

{% block pageTitle %}GOV.UK - HMCTS Case Worker{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      <h1 class="govuk-heading-xl">Case Worker Dashboard</h1>
      
      <h2 class="govuk-heading-l">Active Tasks</h2>

      {% if error %}
        <div class="govuk-error-summary" data-module="govuk-error-summary">
          <div role="alert">
            <h2 class="govuk-error-summary__title">There is a problem</h2>
            <div class="govuk-error-summary__body">
              <p>{{ error }}</p>
            </div>
          </div>
        </div>
      {% endif %}

      <p class="govuk-body">
        {{ govukButton({
          text: "Create new task",
          href: "/tasks/new",
          classes: "govuk-button--secondary"
        }) }}
      </p>

      {% if tasks and tasks.length > 0 %}
        {% set tableRows = [] %}
        {% for task in tasks %}
          {% set actionHtml %}
            {% if task.links and task.links.update %}
              <a href="/tasks/{{ task.id }}/edit" class="govuk-link">Edit</a>
            {% else %}
              <span class="govuk-body" style="color: #505a5f;">Edit</span>
            {% endif %}
            {% if task.links and task.links.delete %}
              {% if task.links and task.links.update %} | {% else %}<span style="color: #505a5f;"> | </span>{% endif %}
              <a href="/tasks/{{ task.id }}/delete" class="govuk-link" onclick="event.preventDefault(); if(confirm('Are you sure?')) { document.getElementById('delete-form-{{ task.id }}').submit(); }">Delete</a>
              <form id="delete-form-{{ task.id }}" method="post" action="/tasks/{{ task.id }}/delete" style="display:none;"></form>
            {% else %}
              <span style="color: #505a5f;"> | Delete</span>
            {% endif %}
          {% endset %}
          {% set tableRows = (tableRows.push([
            { text: task.title },
            { text: task.status },
            { text: task.dueDate | date("DD/MM/YYYY") },
            { html: actionHtml }
          ]), tableRows) %}
        {% endfor %}

        {{ govukTable({
          caption: "Tasks",
          captionClasses: "govuk-table__caption--m",
          head: [
            { text: "Title" },
            { text: "Status" },
            { text: "Due Date" },
            { text: "Actions" }
          ],
          rows: tableRows
        }) }}

        {% if pageDetails.totalPages > 1 %}
          {% set paginationItems = [] %}
          {% for page in range(0, pageDetails.totalPages) %}
            {% set paginationItems = (paginationItems.push({
              number: page + 1,
              href: '/tasks?page=' + page + '&size=' + pageDetails.pageSize,
              current: page == pageDetails.currentPage
            }), paginationItems) %}
          {% endfor %}
          {# Convert API links to frontend paths by replacing /v1/tasks with /tasks #}
          {% set prevHref = links.prev | replace('/v1/tasks', '/tasks') if links.prev else '' %}
          {% set nextHref = links.next | replace('/v1/tasks', '/tasks') if links.next else '' %}
          {% if prevHref and nextHref %}
            {{ govukPagination({
              previous: { href: prevHref },
              next: { href: nextHref },
              items: paginationItems
            }) }}
          {% elif prevHref %}
            {{ govukPagination({
              previous: { href: prevHref },
              items: paginationItems
            }) }}
          {% elif nextHref %}
            {{ govukPagination({
              next: { href: nextHref },
              items: paginationItems
            }) }}
          {% else %}
            {{ govukPagination({
              items: paginationItems
            }) }}
          {% endif %}
        {% endif %}
      {% else %}
        <p class="govuk-body">No tasks found.</p>
      {% endif %}
    </div>
  </div>
{% endblock %}